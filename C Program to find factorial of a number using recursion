#include <stdio.h>
long int fact(int n);
int main() {
    int num;
    long int result;
    printf("Enter a number:");
    scanf("%ld",&num);
    result=fact(num);
    printf("Factorial = %ld", result); 
    return 0;
}
long int fact(int n){
    if(n>=1)
    {
        return n*fact(n-1);
    }
    else{
        return 1;
    }
}
